# ──────────────────────────────────────────────
# Supabase
# ──────────────────────────────────────────────
# Your Supabase project URL and anonymous key.
# Find these in: Supabase Dashboard → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# ──────────────────────────────────────────────
# Session
# ──────────────────────────────────────────────
# Secret used to sign session cookies. Generate with: openssl rand -base64 32
SESSION_SECRET=

# ──────────────────────────────────────────────
# AI (Google Gemini)
# ──────────────────────────────────────────────
# Powers AI insights, chat, and auto-categorization.
# Get a key at: https://aistudio.google.com/apikey
GEMINI_API_KEY=

# ──────────────────────────────────────────────
# Web Push Notifications (VAPID)
# ──────────────────────────────────────────────
# Generate a key pair with: npx web-push generate-vapid-keys
NEXT_PUBLIC_MONEY_PUSH_VAPID_PUBLIC_KEY=
MONEY_PUSH_VAPID_PRIVATE_KEY=
MONEY_PUSH_VAPID_SUBJECT=mailto:you@example.com

# Secret to authenticate the Vercel cron endpoint (/api/push/cron).
# Generate with: openssl rand -base64 32
CRON_SECRET=

# ──────────────────────────────────────────────
# Vercel (optional)
# ──────────────────────────────────────────────
NEXT_PUBLIC_ENABLE_ANALYTICS=false
NEXT_PUBLIC_ENABLE_SPEED_INSIGHTS=false
